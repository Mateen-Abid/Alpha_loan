# Environment Configuration Template
# Copy this file to .env and fill in actual values

# Django
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=alpha_loan
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Celery & Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CACHE_LOCATION=redis://127.0.0.1:6379/1

# APIs
HEYMARKET_API_KEY=your-heymarket-api-key
HEYMARKET_BASE_URL=https://api.heymarket.io/v1
HEYMARKET_WEBHOOK_URL=https://yourdomain.com/webhooks/sms/
HEYMARKET_WEBHOOK_SECRET=your-webhook-secret

# iCollector Partner Gateway
ICOLLECTOR_BASE_URL=https://app.icollector.ai
ICOLLECTOR_API_TOKEN=your-icollector-bearer-token
ICOLLECTOR_API_KEY=your-icollector-bearer-token
ICOLLECTOR_TENANT=ilowns
# Request signing/verification headers:
# X-Partner-Timestamp, X-Partner-Nonce, X-Partner-Signature: sha256=<hex>
# Use inbound secret to SIGN partner requests to iCollector.
ICOLLECTOR_INBOUND_SECRET=your-icollector-inbound-secret
# Use outbound secret to VERIFY webhook callbacks from iCollector.
ICOLLECTOR_OUTBOUND_SECRET=your-icollector-outbound-secret

TELNYX_API_KEY=your-telnyx-api-key
TELNYX_WEBHOOK_URL=https://yourdomain.com/webhooks/voice/
TELNYX_WEBHOOK_SECRET=your-telnyx-webhook-secret

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

GMAIL_CREDENTIALS_FILE=path/to/gmail/credentials.json

# AI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo

# Security
ENCRYPTION_KEY=your-fernet-encryption-key

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Email (for production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
